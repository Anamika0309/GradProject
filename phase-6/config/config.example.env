# ──────────────────────────────────────────────────────────────────────────────
# Phase 6 – API Credentials Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Reddit API (FREE) ──────────────────────────────────────────────────────────
# How to get:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "Create App" (choose type: script)
#   3. Set redirect URI to: http://localhost:8080
#   4. Copy the client_id (under the app name) and client_secret
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=SpotifyReviewEngine/1.0 (by u/your_reddit_username)

# ── YouTube Data API v3 (FREE) ─────────────────────────────────────────────────
# How to get:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (e.g., "spotify-review-engine")
#   3. Enable "YouTube Data API v3" from the API Library
#   4. Go to Credentials → Create Credentials → API Key
#   5. Paste the key below
# Free quota: 10,000 units/day (~1,500–2,000 comments)
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Scraper Settings ───────────────────────────────────────────────────────────
# Max reviews to fetch per country for App Store
APP_STORE_MAX_PER_COUNTRY=400

# Max reviews per sort type for Play Store
PLAY_STORE_MAX_PER_SORT=1000

# Reddit: max posts per subreddit per listing (hot/top/new)
REDDIT_MAX_POSTS_PER_LISTING=500

# Community forum: max pages to crawl per board
FORUM_MAX_PAGES=20

# YouTube: max comments per video
YOUTUBE_MAX_COMMENTS_PER_VIDEO=300

# Min word count to keep a review (shorter ones are filtered out)
MIN_WORD_COUNT=10

# Delay in seconds between requests (respect rate limits)
REQUEST_DELAY_SECONDS=1.5
